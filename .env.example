# Closeli Remote Stream Server
# Copy to .env and fill in your values
#
# Usage:
#   docker compose up -d                          # Camera 1 only
#   docker compose --profile camera2 up -d        # Add camera 2
#   docker compose --profile all up -d            # All cameras
#
# Endpoints:
#   http://localhost:8081/video   - Camera 1 MJPEG
#   http://localhost:8081/audio   - Camera 1 audio
#   http://localhost:8081/status  - Camera 1 status

# =============================================================================
# Closeli Account
# =============================================================================
CLOSELI_EMAIL=user@example.com
CLOSELI_PASSWORD=your_password

# =============================================================================
# Product Credentials
# Extract from the APK (see project docs for methods)
# =============================================================================
PRODUCT_KEY=
PRODUCT_SECRET=

# =============================================================================
# Cameras
# Device ID format: xxxxS_<mac_no_colons>
# Find your camera MAC in the Eoolii app under device settings
# =============================================================================

# Camera 1 - exposed on port 8081
CAMERA1_DEVICE_ID=xxxxS_000000000000

# Camera 2 - exposed on port 8082
#CAMERA2_DEVICE_ID=xxxxS_000000000000

# Camera 3 - exposed on port 8083
#CAMERA3_DEVICE_ID=xxxxS_000000000000

# Camera 4 - exposed on port 8084
#CAMERA4_DEVICE_ID=xxxxS_000000000000
