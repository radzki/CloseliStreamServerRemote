# Closeli Remote Stream Server
# Copy to .env and fill in your values
#
# Usage:
#   python3 relay_remote_client.py                 # Auto-discover all cameras
#   python3 relay_remote_client.py -d xxxxS_abc123 # Single camera only
#   python3 relay_remote_client.py --discover-only  # List cameras, then exit
#   docker compose up -d                            # Run in container
#
# Endpoints (cameras auto-discovered):
#   http://localhost:8080/                          - Index (all cameras)
#   http://localhost:8080/video/<device_id>         - MJPEG stream
#   http://localhost:8080/audio/<device_id>         - Audio stream
#   http://localhost:8080/status                    - All cameras status

# =============================================================================
# Closeli Account
# =============================================================================
CLOSELI_EMAIL=user@example.com
CLOSELI_PASSWORD=your_password

# =============================================================================
# Product Credentials (from APK)
# =============================================================================
PRODUCT_KEY=c90466a2-6ea
PRODUCT_SECRET=PzEIWxPeAwuNF8sWRzc9
